% Custom style for uoh-sqak HW3 article
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{article}[2026/06/06 uoh-sqak article style]

% Geometry
\RequirePackage[a4paper, top=2.5cm, bottom=2.5cm, left=3cm, right=2.5cm]{geometry}

% Fonts and encoding (GNU FreeFont — full Unicode including Hebrew)
\RequirePackage{fontspec}
\setmainfont{FreeSerif}[
  BoldFont=FreeSerifBold,
  ItalicFont=FreeSerifItalic,
  BoldItalicFont=FreeSerifBoldItalic
]
\setsansfont{FreeSans}[
  BoldFont=FreeSansBold,
  ItalicFont=FreeSansOblique,
  BoldItalicFont=FreeSansBoldOblique,
]
\setmonofont{FreeMono}[
  BoldFont=FreeMonoBold,
  ItalicFont=FreeMonoOblique,
  BoldItalicFont=FreeMonoBoldOblique,
]

% Language support (BiDi — Hebrew + English)
\RequirePackage{polyglossia}
\setmainlanguage{english}
\setotherlanguage{hebrew}
\newfontfamily\hebrewfont[Script=Hebrew]{FreeSerif}

% Math
\RequirePackage{amsmath, amssymb, amsthm}
\RequirePackage{mathtools}

% Graphics and figures
\RequirePackage{graphicx}
\RequirePackage{float}
\RequirePackage{tikz}
\usetikzlibrary{shapes.geometric, arrows.meta, positioning, fit, backgrounds}

% Tables
\RequirePackage{booktabs}
\RequirePackage{longtable}
\RequirePackage{tabularx}

% Colors
\RequirePackage{xcolor}
\definecolor{uohblue}{RGB}{0, 64, 128}
\definecolor{uohgray}{RGB}{100, 100, 100}

% Headers and footers
\RequirePackage{fancyhdr}
\setlength{\headheight}{15pt}
\pagestyle{fancy}
\fancyhf{}
\fancyhead[L]{\small\textcolor{uohgray}{Multi-Agent Orchestration Patterns}}
\fancyhead[R]{\small\textcolor{uohgray}{Salah Qadah \& Andalus Kalash}}
\fancyfoot[C]{\thepage}
\renewcommand{\headrulewidth}{0.4pt}

% Bibliography (biblatex + biber) — numeric-comp: numbered refs [1][2]→[1,2]
\RequirePackage[backend=biber, style=numeric-comp, sorting=nyt, hyperref=true]{biblatex}
\addbibresource{bib/references.bib}

% Hyperlinks
\RequirePackage[colorlinks=true, linkcolor=uohblue, citecolor=uohblue, urlcolor=uohblue]{hyperref}

% etoc — enables per-chapter TOC entry style customisation (used by ch05 for RTL entries)
% \etocstandardlines: use the report class's own \l@chapter/\l@section styles by default.
% Without this, etoc's own default style shows "6.1, p. 12" format for all TOC lines.
\RequirePackage{etoc}
\etocstandardlines

% Dot leader matching \@dottedtocline (4.5mu spacing) for use in \addtocontents{toc}.
% Must be defined here (where @ is a letter) so \m@th is parsed as a control sequence.
% Usage in document body: \protect\hebrewdotleaders
\newcommand{\hebrewdotleaders}{%
  \leaders\hbox{$\m@th\mkern 4.5mu.\mkern 4.5mu$}\hfill\nobreak}

% Listings / code
\RequirePackage{listings}
\lstset{
  basicstyle=\ttfamily\small,
  breaklines=true,
  frame=single,
  numbers=left,
  numberstyle=\tiny\color{uohgray},
}

% Chapter/section formatting (LTR default)
\RequirePackage{titlesec}
\titleformat{\chapter}[display]
  {\normalfont\LARGE\bfseries\color{uohblue}}
  {\chaptertitlename\ \thechapter}{12pt}{\LARGE}
\titleformat{\section}
  {\normalfont\Large\bfseries\color{uohblue}}{\thesection}{1em}{}
\titleformat{\subsection}
  {\normalfont\large\bfseries}{\thesubsection}{1em}{}

% RTL heading format — use \hebrewheadingformat before a Hebrew chapter
% and \defaultheadingformat after it to restore LTR alignment.
\newcommand{\hebrewheadingformat}{%
  \titleformat{\chapter}[display]%
    {\normalfont\LARGE\bfseries\color{uohblue}}%
    {\chaptertitlename\ \thechapter}{12pt}{\LARGE\raggedleft}%
  % Hebrew sections: empty label; caller embeds \thesection at the END of the
  % title text so that with \raggedleft the number appears at the right edge.
  % Pattern: \section[TOC-title]{\texthebrew{title}\quad\thesection}
  \titleformat{\section}[block]%
    {\normalfont\Large\bfseries\color{uohblue}\raggedleft}%
    {}%
    {0em}%
    {}%
  \titleformat{\subsection}[block]%
    {\normalfont\large\bfseries\raggedleft}%
    {}%
    {0em}%
    {}%
}
\newcommand{\defaultheadingformat}{%
  \titleformat{\chapter}[display]%
    {\normalfont\LARGE\bfseries\color{uohblue}}%
    {\chaptertitlename\ \thechapter}{12pt}{\LARGE}%
  \titleformat{\section}%
    {\normalfont\Large\bfseries\color{uohblue}}{\thesection}{1em}{}%
  \titleformat{\subsection}%
    {\normalfont\large\bfseries}{\thesubsection}{1em}{}%
}

% Table of contents depth
\setcounter{tocdepth}{2}
\setcounter{secnumdepth}{2}
