# Anthropic API key (optional — Claude CLI login preferred)
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# LaTeX compiler paths (defaults: lualatex and biber from PATH)
LUALATEX_PATH=lualatex
BIBER_PATH=biber

# Optional: Serper/Tavily API keys (not needed — DuckDuckGo used by default)
SERPER_API_KEY=
